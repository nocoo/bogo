{
	"$schema": "https://biomejs.dev/schemas/2.4.16/schema.json",
	"assist": { "actions": { "source": { "organizeImports": "on" } } },
	"linter": {
		"enabled": true,
		"rules": {
			"correctness": {
				"noUnusedImports": "error",
				"noUnusedVariables": "error",
				"noNodejsModules": "off",
				"useImportExtensions": "off",
				"noUndeclaredDependencies": "off",
				"noUndeclaredVariables": "off"
			},
			"security": {
				"noDangerouslySetInnerHtml": "error"
			},
			"style": {
				"noNonNullAssertion": "error",
				"useConst": "error",
				"useNamingConvention": "off",
				"noDefaultExport": "off",
				"useFilenamingConvention": "off"
			},
			"complexity": {
				"noExcessiveCognitiveComplexity": "off"
			},
			"suspicious": {
				"noConsole": "off",
				"noReactSpecificProps": "off",
				"useAwait": "off"
			},
			"performance": {
				"useTopLevelRegex": "off",
				"noBarrelFile": "off"
			},
			"nursery": {}
		}
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab",
		"indentWidth": 2,
		"lineWidth": 100
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "double",
			"semicolons": "always"
		}
	},
	"files": {
		"includes": [
			"**",
			"!**/node_modules",
			"!**/dist",
			"!**/.turbo",
			"!**/coverage",
			"!**/.wrangler",
			"!**/.claude/skills",
			"!**/packages/worker/static",
			"!**/scripts",
			"!**/test-results",
			"!**/playwright-report",
			"!**/blob-report",
			"!**/.clip-output",
			"!**/packages/ui/src/index.css"
		]
	}
}
