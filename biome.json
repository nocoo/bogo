{
	"$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
	"organizeImports": {
		"enabled": true
	},
	"linter": {
		"enabled": true,
		"rules": {
			"all": true,
			"correctness": {
				"noUnusedImports": "error",
				"noUnusedVariables": "error",
				"noNodejsModules": "off",
				"useImportExtensions": "off",
				"noUndeclaredDependencies": "off",
				"noUndeclaredVariables": "off"
			},
			"security": {
				"noDangerouslySetInnerHtml": "error"
			},
			"style": {
				"noNonNullAssertion": "error",
				"useConst": "error",
				"useNamingConvention": "off",
				"noDefaultExport": "off",
				"useFilenamingConvention": "off"
			},
			"complexity": {
				"noExcessiveCognitiveComplexity": "off"
			},
			"suspicious": {
				"noConsole": "off",
				"noReactSpecificProps": "off",
				"useAwait": "off"
			},
			"performance": {
				"useTopLevelRegex": "off",
				"noBarrelFile": "off"
			},
			"nursery": {
				"all": false
			}
		}
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab",
		"indentWidth": 2,
		"lineWidth": 100
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "double",
			"semicolons": "always"
		}
	},
	"files": {
		"ignore": [
			"node_modules",
			"dist",
			".turbo",
			"coverage",
			".wrangler",
			".claude/skills",
			"packages/worker/static",
			"scripts"
		]
	}
}
