# pre-commit: L1 (Unit tests + coverage) + G1 (Static analysis)
# Run independent stages in parallel; fail fast on any non-zero exit.
set -o pipefail
HOOK_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$HOOK_DIR/../scripts/ensure-tools.sh"
require_tool gitleaks "secrets scanning"

TMPDIR_HOOK=$(mktemp -d -t bogo-precommit-XXXXXX)
trap 'rm -rf "$TMPDIR_HOOK"' EXIT

run_bg() {
  local name="$1"; shift
  ( "$@" >"$TMPDIR_HOOK/$name.log" 2>&1; echo $? >"$TMPDIR_HOOK/$name.exit" ) &
  eval "PID_$name=$!"
}

wait_stage() {
  local name="$1" pid_var="PID_$1" pid status
  pid=${!pid_var}
  wait "$pid" 2>/dev/null || true
  status=$(cat "$TMPDIR_HOOK/$name.exit" 2>/dev/null || echo 1)
  echo "━━━ $name (exit=$status) ━━━"
  cat "$TMPDIR_HOOK/$name.log"
  if [ "$status" -ne 0 ]; then
    echo "❌ pre-commit stage '$name' failed" >&2
    exit "$status"
  fi
}

# Launch non-git-modifying stages concurrently
run_bg unit_cov   bash scripts/check-coverage.sh 90 95
run_bg typecheck  bun turbo typecheck
run_bg gitleaks   gitleaks protect --staged --no-banner
run_bg routes     bun run gate:routes
run_bg pages      bun run gate:pages

# Wait in declaration order so logs print deterministically
wait_stage unit_cov
wait_stage typecheck
wait_stage gitleaks
wait_stage routes
wait_stage pages

# lint-staged uses git stash which conflicts with concurrent stages
echo "━━━ lint (exit=pending) ━━━"
if ! bunx lint-staged; then
  echo "❌ pre-commit stage 'lint' failed" >&2
  exit 1
fi
echo "━━━ lint (exit=0) ━━━"

echo "✔ pre-commit passed (L1 + G1)"
